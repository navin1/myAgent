# ── GCP / Vertex AI ──────────────────────────────────────────────────────────
# GCP project used for Vertex AI / Gemini API authentication
GCP_PROJECT_ID=my-gcp-project

# Region for Vertex AI model serving
VERTEX_LOCATION=us-central1

# ── BigQuery ──────────────────────────────────────────────────────────────────
# Comma-separated list of GCP project IDs the agent is allowed to query
BQ_PROJECTS=project-a,project-b

# Project billed for BigQuery query costs (defaults to first entry in BQ_PROJECTS)
BQ_BILLING_PROJECT=project-a

# Maximum rows returned from a SQL query (0 = unlimited)
MAX_SQL_ROWS=0

# ── Gemini model ──────────────────────────────────────────────────────────────
# Gemini model ID used for all agent completions
GEMINI_MODEL=gemini-2.0-flash

# ── Logging ───────────────────────────────────────────────────────────────────
# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Excel: general data loading (DuckDB) ─────────────────────────────────────
# Root directory scanned recursively for .xlsx / .xlsm / .xls files.
# All files found here are loaded into DuckDB and become queryable via SQL.
# Leave blank to disable Excel/DuckDB querying entirely.
EXCEL_DATA_PATH=./data

# Number of header rows used when loading ALL Excel files into DuckDB.
# This applies to general SQL querying only — spec parsing uses the
# type-specific settings below (EXCEL_MASTER_HEADER_ROWS / EXCEL_MAPPING_HEADER_ROWS).
EXCEL_HEADER_ROWS=1

# ── Excel: spec-file classification (folder-based) ───────────────────────────
# Files are classified by folder location — filenames do not matter.
#
# Scanning strategy (applied in order):
#   1. Both EXCEL_MASTER_PATH and EXCEL_MAPPING_PATH set:
#        Files in EXCEL_MASTER_PATH/**  → Master Sheets
#        Files in EXCEL_MAPPING_PATH/** → Mapping Sheets
#        Files outside both folders     → skipped (not indexed)
#   2. Only EXCEL_MAPPING_PATH set (no EXCEL_MASTER_PATH):
#        Files in EXCEL_MAPPING_PATH/** → Mapping Sheets
#        All other files under EXCEL_DATA_PATH → Master Sheets
#   3. Neither path set:
#        All files under EXCEL_DATA_PATH → Master Sheets
#
# Example folder layout:
#   ./data/
#   ├── mappings/                    ← EXCEL_MAPPING_PATH=./data/mappings
#   │   ├── orders/
#   │   │   ├── Orders1.xlsx         → Mapping Sheet (EXCEL_MAPPING_HEADER_ROWS)
#   │   │   ├── Orders2.xlsx         → Mapping Sheet (EXCEL_MAPPING_HEADER_ROWS)
#   │   │   └── Orders3.xlsx         → Mapping Sheet (EXCEL_MAPPING_HEADER_ROWS)
#   │   └── customers/
#   │       └── Customers.xlsx       → Mapping Sheet (EXCEL_MAPPING_HEADER_ROWS)
#   └── master/                      ← EXCEL_MASTER_PATH=./data/master
#       ├── real.xlsx                → Master Sheet  (EXCEL_MASTER_HEADER_ROWS)
#       └── cust/
#           ├── Cust1.xlsx           → Master Sheet  (EXCEL_MASTER_HEADER_ROWS)
#           └── Cust2.xlsx           → Master Sheet  (EXCEL_MASTER_HEADER_ROWS)

# Folder containing all Master Sheet files (absolute or relative path).
# Every Excel file inside this folder and its subfolders → Master Sheet.
# Leave blank → fallback behaviour described above applies.
EXCEL_MASTER_PATH=./data/master

# Folder containing all Mapping Sheet files (absolute or relative path).
# Every Excel file inside this folder and its subfolders → Mapping Sheet.
# Leave blank → all Excel files under EXCEL_DATA_PATH are treated as Master Sheets.
EXCEL_MAPPING_PATH=./data/mappings

# Number of header rows in Master Sheet files (structural / reference definitions)
EXCEL_MASTER_HEADER_ROWS=1

# Number of header rows in Mapping Sheet files (use 2+ for merged/multi-level headers)
EXCEL_MAPPING_HEADER_ROWS=2

# ── Composer V3 ───────────────────────────────────────────────────────────────
# GCP project containing the target Composer V3 environment.
# Defaults to GCP_PROJECT_ID if not set.
COMPOSER_PROJECT_ID=my-gcp-project

# Region of the target Composer V3 environment.
# Defaults to VERTEX_LOCATION if not set.
COMPOSER_LOCATION=us-central1

# Name of the specific Composer V3 environment to connect to.
# Enables: DAG tracing, Airflow REST API, DAG SQL extraction, DAG optimization.
# Leave blank to disable all Airflow / DAG features.
COMPOSER_ENVIRONMENT=my-composer-env

# GCS bucket holding the Composer DAG Python files.
# Leave blank to auto-discover from the Composer API using COMPOSER_ENVIRONMENT above.
COMPOSER_DAG_BUCKET=

# Timeout in seconds for all Airflow REST API calls
AIRFLOW_API_TIMEOUT=30

# ── GCS: SQL transformation scripts ──────────────────────────────────────────
# GCS bucket containing .sql transformation files.
# Enables: list_sql_files, find_sql_for_table, read_sql_file tools.
# Leave blank to disable GCS SQL features (read_gcs_path remains available).
SQL_GCS_BUCKET=my-sql-scripts-bucket

# Path prefix within SQL_GCS_BUCKET to narrow file listings.
# Examples: "sql/"  "transformations/"  "scripts/bq/"
# Leave blank to search the entire bucket.
SQL_GCS_PREFIX=sql/

# ── Git Repository ────────────────────────────────────────────────────────────
# HTTPS or SSH URL of the repository that holds DAG and SQL source files.
# Enables: list_git_files, read_git_file, find_dag_in_git, find_sql_in_git tools.
# Leave blank to disable all Git features.
# Examples:
#   HTTPS → https://github.com/your-org/your-repo.git
#   SSH   → git@github.com:your-org/your-repo.git
GIT_REPO_URL=https://github.com/your-org/your-repo.git

# Branch to check out, pull from, and push to.
GIT_BRANCH=main

# Absolute local path where the repo will be cloned (created automatically).
GIT_LOCAL_PATH=/tmp/dbconnect_git_repo

# Personal Access Token for HTTPS authentication.
# Injected into the clone URL as https://<token>@host/…
# Leave blank when using SSH key authentication.
GIT_TOKEN=

# Subdirectory inside the repo that contains Airflow DAG (.py) files.
GIT_DAG_PATH=dags/

# Subdirectory inside the repo that contains SQL transformation (.sql) files.
GIT_SQL_PATH=sql/

# Committer identity stamped on commits created by the agent.
GIT_COMMIT_USER_NAME=DBConnect Agent
GIT_COMMIT_USER_EMAIL=dbconnect@example.com

# ── Schema Audit (MySQL → BigQuery reconciliation) ────────────────────────────
# GCP project that hosts the HEADER_VIEW and DETAIL_VIEW metadata tables.
# Defaults to GCP_PROJECT_ID if not set.
SCHEMA_METADATA_PROJECT=my-gcp-project

# BQ target project for tables where deployed_to_prod=1.
# Leave blank to default to SCHEMA_METADATA_PROJECT.
SCHEMA_BQ_PROJECT_PROD=my-prod-project

# BQ target project for UAT / non-prod tables.
# Leave blank to default to SCHEMA_METADATA_PROJECT.
SCHEMA_BQ_PROJECT_UAT=my-uat-project

# Fully-qualified BigQuery views for streamed-table metadata.
# Leave blank to use defaults derived from SCHEMA_METADATA_PROJECT:
#   <SCHEMA_METADATA_PROJECT>.raw_sls_v.datstream_header_v
#   <SCHEMA_METADATA_PROJECT>.raw_sls_v.datstream_detail_v
SCHEMA_HEADER_VIEW=
SCHEMA_DETAIL_VIEW=

# Directory where generated Excel reports and DDL JSON files are written.
# Leave blank to write to the current working directory.
SCHEMA_AUDIT_OUTPUT_DIR=./reports
